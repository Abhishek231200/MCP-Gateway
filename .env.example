# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mcp_gateway
POSTGRES_USER=mcp_user
POSTGRES_PASSWORD=mcp_password
DATABASE_URL=postgresql+asyncpg://mcp_user:mcp_password@localhost:5432/mcp_gateway

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ─── FastAPI ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── LLM Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── GitHub MCP ───────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Slack MCP ────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ─── Jira MCP ─────────────────────────────────────────────────────────────────
JIRA_URL=https://yourworkspace.atlassian.net
JIRA_API_TOKEN=
JIRA_USER_EMAIL=

# ─── Google Drive MCP ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Security Gateway (OPA) ───────────────────────────────────────────────────
# OPA_URL is overridden to http://opa:8181 inside Docker Compose automatically
OPA_URL=http://localhost:8181
# JSON map of actor name → role (admin | engineer | viewer)
ACTOR_ROLES={"abhishek": "admin", "user": "engineer", "demo-user": "engineer", "readonly-user": "viewer", "system": "admin", "loadtest-reader": "viewer", "loadtest-writer": "engineer"}

# ─── API Key Auth ──────────────────────────────────────────────────────────────
# JSON map of API key → {actor, role}. Leave empty ({}) to disable.
API_KEYS={"sk-admin-demo": {"actor": "abhishek", "role": "admin"}, "sk-eng-demo": {"actor": "demo-user", "role": "engineer"}, "sk-readonly": {"actor": "readonly-user", "role": "viewer"}}

# ─── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

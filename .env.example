# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mcp_gateway
POSTGRES_USER=mcp_user
POSTGRES_PASSWORD=mcp_password
DATABASE_URL=postgresql+asyncpg://mcp_user:mcp_password@localhost:5432/mcp_gateway

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ─── FastAPI ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── LLM Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# ─── GitHub MCP ───────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Slack MCP ────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ─── Google Drive MCP ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
